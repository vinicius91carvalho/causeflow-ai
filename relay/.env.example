# CauseFlow Relay — open-source local runtime env vars.
#
# This file contains only the relay's own env vars. It references no paid or
# external SaaS provider configuration of any kind; the relay runs end-to-end
# against the bundled docker-compose stack using only the values below.

# Control-plane / tenant identity used by the relay's outbound WebSocket.
RELAY_TOKEN=harness-smoke-token
TENANT_ID=harness-tenant
CONTROL_PLANE_URL=ws://relay-control-plane-stub:3000/v1/relay/connect

# Local customer PostgreSQL (relay-postgres service in docker-compose).
PG_HOST=relay-postgres
PG_PORT=5432
PG_DATABASE=relay
PG_USER=relay
PG_PASSWORD=relay

# Local customer MongoDB (relay-mongo service in docker-compose).
MONGO_URI=mongodb://relay-mongo:27017
MONGO_DATABASE=relay

# Optional runtime toggles (default to true).
MASKING_ENABLED=true
AUDIT_ENABLED=true
