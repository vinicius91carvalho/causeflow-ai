  "incidentId": "9653196b-bfd9-46a8-be5e-f358008f41ac",
  "final": {
    "status": "awaiting_approval",
    "rootCause": "The order-service is experiencing a connection pool exhaustion failure caused by the combination of three factors: (1) a fixed-size DB connection pool with no adaptive backoff on checkout failure, (2) insufficient task capacity (only 2 desired tasks) for the current load, and (3) no lock contention to offload the bottleneck. Under sustained high load, the pool fills to its maximum, all new checkout requests queue up waiting, and the service cannot process new orders. Because there is no backoff or circuit-breaking logic, the service threads remain blocked waiting for connections that will never be returned, leading to cascading thread-pool saturation and elevated CPU. The issue is load-driven — no recent deploy or config change triggered it — so the root cause is a capacity/architecture mismatch between the configured pool size and the actual demand.",
    "remCount": 1
  }
