  "incidentId": "10b872af-46e7-49ad-9e2b-3d9388db7657",
  "final": {
    "status": "awaiting_approval",
    "rootCause": "The order-service connection pool is exhausted under sustained high load. The service runs with only 2 ECS tasks (insufficient for the current load), CPU is sustained above 90%, and the DB client uses a fixed pool size with no adaptive backoff on checkout failures. When the pool reaches its maximum, requests block indefinitely waiting for a connection that will never be returned because no connections are being released (threads are stuck in checkout). This creates a cascading failure: blocked threads consume the thread pool, preventing new connections from being acquired, which further starves the pool. The issue is load-driven (no recent deploy) and is a capacity + resilience problem: the pool is too small for the load, the task count is too low to absorb the load, and the client has no backoff to fail fast.",
    "remCount": 1
  }
