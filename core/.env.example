# CauseFlow — open-source local runtime environment (AC-053).
#
# This is the ONLY configuration required to run CauseFlow locally via
# `docker compose up -d`. Every AWS / Stripe / Clerk / Sentry / Langfuse /
# Svix / Slack / Composio / Mastra integration is a no-op when its env var is
# absent, so you do not need any paid/external SaaS credentials.
#
# Hindsight (long-term agent memory) is bundled as a docker-compose container;
# no key is needed for local use.
# ANTHROPIC_API_KEY is optional — enables Anthropic override for triage/investigation.
# Without it Core uses the local Ornith connector (LLM_BASE_URL / LLM_MODEL).

# === Application port (the API is published on 3099, this is the container port) ===
PORT=5171

# === Postgres (bundled causeflow-postgres container) ===
DATABASE_URL=postgresql://causeflow:causeflow@causeflow-postgres:5432/causeflow

# === Redis (bundled container) ===
REDIS_URL=redis://redis:6379

# === Auth (local JWT — change this in production) ===
JWT_SECRET=oss-dev-jwt-secret-change-me

# === Inbound webhooks (Datadog / Grafana / CloudWatch HMAC) ===
WEBHOOK_SECRET=oss-dev-webhook-secret

# === Token encryption (AES-256-GCM key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ===
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# === Hindsight (bundled container) ===
HINDSIGHT_BASE_URL=http://hindsight:8888
HINDSIGHT_API_KEY=

# === Anthropic (optional override — when set, replaces the local Ornith connector) ===
ANTHROPIC_API_KEY=

# === Local LLM — Ornith 9B via OpenAI-compatible llama.cpp (AC-054) ===
# Start Ornith: ~/tools/llama-session.sh (model alias Ornith-1.0-9B-code on :8081)
# Host dev: http://127.0.0.1:8081/v1
# Docker compose: http://host.docker.internal:8081/v1
# AC-055: when Ornith is stopped, /health reports llm=degraded and triage/investigation
# fail closed within a 5s reachability probe (no silent DeterministicLLMClient pass).
LLM_CONNECTOR=ornith
LLM_BASE_URL=http://127.0.0.1:8081/v1
LLM_MODEL=Ornith-1.0-9B-code

# === DeepSeek V4 Flash fallback when Ornith 32k context is insufficient (AC-059) ===
# Switch via LLM_CONNECTOR=deepseek-opencode|deepseek-nim or PUT /v1/oss/llm-connector.
# Populate credentials from the operator host at runtime — never commit secrets:
#   ~/.pi/agent/auth.json  → opencode-go.key → OPENCODE_API_KEY
#   ~/.pi/agent/auth.json  → nvidia.key     → NVIDIA_API_KEY
#   ~/.config/opencode     → provider API keys
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=deepseek-v4-flash-free
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=deepseek-ai/deepseek-v4-flash

# === Runnable test application (OSS integration target — AC-058) ===
# Compose: docker compose up -d causeflow-test-app
# Host dev: TEST_APP_PORT=5190 node test-app/server.mjs
TEST_APP_PORT=5190
TEST_APP_BASE_URL=http://127.0.0.1:5190
STUB_UPSTREAM_BASE_URL=http://127.0.0.1:5190
STUB_UPSTREAM_CORE_BASE_URL=http://127.0.0.1:5171

# === Web Push (VAPID keys — one-time generation required for push notifications) ===
VAPID_PUBLIC_KEY=BBjPUFtJIDWZooY9BmoWJ3wpSsZsWGXaSFFjU6ieR8ngON2F07g0MG_MY_1DrrmPNPRubdZKihE-ALJj9uYT5cE
VAPID_PRIVATE_KEY=Qrn4MAoZ29endhT_VFnzU55Q25C5rBqwldnZBePUwMM
