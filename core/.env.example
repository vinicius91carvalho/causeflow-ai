# CauseFlow — open-source local runtime environment.
#
# This is the ONLY configuration required to run CauseFlow locally via
# `docker compose up -d` (AC-039). Every AWS / Stripe / Clerk / Sentry /
# Langfuse / Svix / Slack / Composio / Mastra integration is a no-op when its
# env var is absent, so you do not need any paid/external SaaS credentials.
#
# Required external SaaS: Hindsight (long-term agent memory) — bundled as a
# docker-compose container, no key needed for local use.
# Optional: ANTHROPIC_API_KEY — enables AI triage/investigation. Without it the
# platform still boots and `/health` reports anthropic: "skipped".

# === Runtime flavour (do not change for the local runtime) ===
CAUSEFLOW_RUNTIME=oss
NODE_ENV=development
PORT=5171
LOG_LEVEL=info

# === Postgres (bundled causeflow-postgres container) ===
DATABASE_URL=postgresql://causeflow:causeflow@causeflow-postgres:5432/causeflow
POSTGRES_HOST=causeflow-postgres
POSTGRES_PORT=5432
POSTGRES_DB=causeflow
POSTGRES_USER=causeflow
POSTGRES_PASSWORD=causeflow

# === Redis (bundled container) ===
REDIS_URL=redis://redis:6379

# === Hindsight (bundled container) ===
HINDSIGHT_BASE_URL=http://hindsight:8888
HINDSIGHT_API_KEY=

# === Anthropic (optional) ===
ANTHROPIC_API_KEY=

# === Auth / webhooks (local JWT + HMAC) ===
JWT_SECRET=oss-dev-jwt-secret-change-me
WEBHOOK_SECRET=oss-dev-webhook-secret

# === Token encryption (AES-256-GCM key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ===
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
