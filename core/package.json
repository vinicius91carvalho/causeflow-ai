{
  "name": "causeflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.dev src/main.ts",
    "backfill:stranded-triage": "tsx scripts/backfill-stranded-triage-incidents.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:eval": "vitest run --config vitest.eval.config.ts",
    "eval:triage": "NODE_OPTIONS='--import tsx/esm' promptfoo eval --env-file .env -c tests/eval/promptfoo/triage.yaml",
    "eval:pipeline": "NODE_OPTIONS='--import tsx/esm' promptfoo eval --env-file .env -c tests/eval/promptfoo/pipeline.yaml",
    "eval:view": "promptfoo view",
    "lint-invariants": "tsx infra/scripts/check-invariants.ts",
    "verify-deploy": "tsx infra/scripts/verify-deploy.ts",
    "verify:ac061": "bash .harness/ac061-verify.sh",
    "build:widget": "pnpm --filter @causeflow/widget build",
    "ci:local": "pnpm typecheck && pnpm lint && pnpm build && pnpm test:run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@anthropic-ai/sdk": "^0.74.0",
    "@aws-sdk/client-api-gateway": "^3.1001.0",
    "@aws-sdk/client-apigatewayv2": "^3.1001.0",
    "@aws-sdk/client-cloudfront": "^3.1001.0",
    "@aws-sdk/client-cloudtrail": "^3.1001.0",
    "@aws-sdk/client-cloudwatch": "^3.991.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.991.0",
    "@aws-sdk/client-codecommit": "^3.1025.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ec2": "^3.991.0",
    "@aws-sdk/client-ecs": "^3.991.0",
    "@aws-sdk/client-eks": "^3.1001.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1001.0",
    "@aws-sdk/client-elasticache": "^3.1001.0",
    "@aws-sdk/client-eventbridge": "^3.1001.0",
    "@aws-sdk/client-kms": "^3.1003.0",
    "@aws-sdk/client-lambda": "^3.991.0",
    "@aws-sdk/client-rds": "^3.1001.0",
    "@aws-sdk/client-route-53": "^3.1001.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/client-sns": "^3.1001.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.991.0",
    "@aws-sdk/client-sts": "^3.991.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@clerk/backend": "^3.2.4",
    "@composio/core": "^0.6.8",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@mastra/core": "^1.23.0",
    "@mastra/dynamodb": "^1.0.3",
    "@mastra/langfuse": "^1.1.0",
    "@mastra/memory": "^1.15.0",
    "@mastra/observability": "^1.7.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/id-generator-aws-xray": "^2.1.0",
    "@opentelemetry/propagator-aws-xray": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@sentry/node": "^10.48.0",
    "@slack/web-api": "^7.15.1",
    "@types/web-push": "^3.6.4",
    "@vectorize-io/hindsight-client": "^0.4.22",
    "ai": "^6.0.158",
    "bullmq": "^5.0.0",
    "electrodb": "^2.14.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "jose": "^5.9.0",
    "langfuse": "^3.38.6",
    "pg": "^8.22.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^22.0.0",
    "svix": "^1.90.0",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.700.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "promptfoo": "^0.120.24",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
