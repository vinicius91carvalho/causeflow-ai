NODE_ENV=test
PORT=3099
LOG_LEVEL=info
AWS_REGION=us-east-1

# CauseFlow infra (LocalStack A — port 4566)
DYNAMODB_ENDPOINT=http://localhost:4566
DYNAMODB_TABLE_NAME=causeflow
SQS_ENDPOINT=http://localhost:4566

# Credential vending → Customer LocalStack (B — port 4567)
STS_ENDPOINT=http://localhost:4567
AWS_ROLE_ARN=arn:aws:iam::000000000000:role/CauseFlowCrossAccountRole

# Cloud Provider → Customer LocalStack (B — port 4567)
CLOUD_PROVIDER_ENDPOINT=http://localhost:4567

REDIS_URL=redis://localhost:6379
JWT_SECRET=smoke-test-secret
JWT_ISSUER=causeflow
JWT_AUDIENCE=causeflow-api
ANTHROPIC_API_KEY=stub-api-key-for-smoke
WEBHOOK_SECRET=smoke-webhook-secret
RELAY_ENABLED=true
RELAY_WS_PATH=/v1/relay/connect

# Langfuse Observability (optional — falls back to Noop if not set)
# Create API keys at http://localhost:3001 after docker-compose up
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3001
