NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# AWS / LocalStack
AWS_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:4566
DYNAMODB_TABLE_NAME=causeflow-local
SQS_ENDPOINT=http://localhost:4566

# SQS Queue URLs (LocalStack)
SQS_ALERT_QUEUE_URL=http://localhost:4566/000000000000/causeflow-alerts
SQS_INVESTIGATION_QUEUE_URL=http://localhost:4566/000000000000/causeflow-investigation
SQS_REMEDIATION_QUEUE_URL=http://localhost:4566/000000000000/causeflow-remediation

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=localstack-jwt-secret-dev
JWT_ISSUER=causeflow
JWT_AUDIENCE=causeflow-api

# Anthropic (leave empty to disable LLM-dependent consumers)
ANTHROPIC_API_KEY=

# Webhook
WEBHOOK_SECRET=dev-webhook-secret

# Langfuse (optional - runs at localhost:3001 via docker-compose)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3001

# Widget / Portal (Web Push Notifications)
VAPID_PUBLIC_KEY=BDgd6vpSg7BSOgzL83H-87vjJbLqTz5Y3YsIHW8jMEuzWXk9JXjsjHdDtypaEWBfAzWBJtTcr96Y-piVbLGhAKo
