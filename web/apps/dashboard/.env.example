# =============================================================================
# CauseFlow AI Dashboard — Environment Variables (open-source local runtime)
# =============================================================================
# Copy this file to `.env.local` for local dev. The open-source runtime does
# NOT use Clerk, Stripe, AWS, Sentry, Loops.so, or SST — none of those
# variables are required or present here (AC-045).
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# --- Core API (required) --------------------------------------------------
# The CauseFlow Core API base URL. Inside the bundled docker-compose network
# the API container is reachable as `http://causeflow-api:5171`. Leave blank
# in local dev (outside Docker) to fall through to the mock Core API client.
CORE_API_URL=http://causeflow-api:5171

# --- Local JWT auth (shared with the Core API container) ------------------
# The Core signs short-lived JWTs with this secret; the dashboard's middleware
# + `withAuth` verify the `__session` cookie against the same value via the
# Core's `/v1/auth/me` endpoint. MUST match the Core container's JWT_SECRET.
JWT_SECRET=oss-dev-jwt-secret-change-me

# --- Runtime mode ---------------------------------------------------------
# `oss` enables StubBillingService plan-gate behavior (AC-048): free+active
# without currentPeriodEnd is treated as an active plan.
CAUSEFLOW_RUNTIME=oss

# --- Optional analytics (blank = no-op, no outbound calls) ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_ID=
