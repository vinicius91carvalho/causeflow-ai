# =============================================================================
# CauseFlow AI Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
#
# SST-managed variables (marked below) are injected automatically during
# `sst deploy`. For local dev, copy values from SST outputs after deploying
# to staging.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth.js (next-auth v5)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=your-secret-here

# The URL of this app (must match callback URLs in Cognito App Client)
# Development: http://127.0.0.1:3001
# Staging:     https://dashboard-staging.causeflow.ai
# Production:  https://dashboard.causeflow.ai
NEXTAUTH_URL=http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# AWS Cognito (SST-managed — populated automatically on deployment)
# For local dev: copy from `sst deploy --stage staging` outputs
# -----------------------------------------------------------------------------
AUTH_COGNITO_ID=your-cognito-client-id
AUTH_COGNITO_SECRET=your-cognito-client-secret
# Format: https://cognito-idp.{region}.amazonaws.com/{userPoolId}
AUTH_COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_xxxxxxxxx

# -----------------------------------------------------------------------------
# Social Login (optional — configure in AWS Console after initial deployment)
# See Social Login Setup section in apps/dashboard/sst.config.ts
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# DynamoDB (SST-managed — populated automatically on deployment)
# For local dev: use the staging table from SST outputs
# -----------------------------------------------------------------------------
DYNAMODB_TABLE_NAME=causeflow-dashboard-staging

# -----------------------------------------------------------------------------
# AWS KMS (SST-managed — populated automatically on deployment)
# For local dev: use the staging KMS key ARN from SST outputs
# -----------------------------------------------------------------------------
KMS_KEY_ARN=arn:aws:kms:us-east-2:409171461008:key/your-key-id

# -----------------------------------------------------------------------------
# AWS Region (must match SST deployment region)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-2
# Internal override used by SDK clients to avoid collision with AWS_REGION env var
AWS_REGION_OVERRIDE=us-east-2

# -----------------------------------------------------------------------------
# Analytics (optional — leave empty to disable)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# -----------------------------------------------------------------------------
# App metadata
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEPLOYMENT_STAGE=development
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3001
# Injected by CI/CD workflow from git tag or commit SHA
APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Stripe (required for billing)
# Use test keys (sk_test_/pk_test_) for local dev and staging.
# Use live keys (sk_live_/pk_live_) for production only.
# Get keys from: https://dashboard.stripe.com/apikeys
# Get webhook secret from: https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (created by the setup-stripe script or via Stripe dashboard)
# Run: pnpm --filter dashboard setup-stripe (after setting STRIPE_SECRET_KEY)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# -----------------------------------------------------------------------------
# Core API (sre-ai backend)
# Leave blank to use mock data. Set CORE_API_URL + CORE_API_JWT_SECRET to connect.
# CORE_API_JWT_SECRET: Shared HMAC secret — MUST match backend JWT_SECRET
# -----------------------------------------------------------------------------
CORE_API_URL=
CORE_API_JWT_SECRET=

# -----------------------------------------------------------------------------
# Sentry (optional — leave empty to disable error tracking)
# NEXT_PUBLIC_SENTRY_DSN: get from Sentry project settings → Client Keys
# SENTRY_ORG / SENTRY_PROJECT: used at build time to upload source maps
# Org: causeflow-ai | Dashboard project ID: 4511214189805568
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://4c496d5b4c0e685f12d4b48d9be48971@o4511214153170944.ingest.us.sentry.io/4511214189805568
SENTRY_ORG=causeflow-ai
SENTRY_PROJECT=causeflow-dashboard
# Build-time only — used by CI to upload source maps to Sentry. Never needed at runtime.
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Development Only
# When AUTH_COGNITO_ID is not set and NODE_ENV=development,
# a mock Credentials provider is automatically enabled.
# Any email/password combination will work for local testing.
# -----------------------------------------------------------------------------
