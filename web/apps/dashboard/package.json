{
  "name": "@causeflow/dashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname localhost -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "biome lint ./src",
    "check-types": "tsc --noEmit --project tsconfig.build.json",
    "test": "cd ../.. && vitest run --project dashboard",
    "test:watch": "cd ../.. && vitest --project dashboard",
    "clean": "rm -rf .next",
    "credits:add": "tsx scripts/add-credits.ts",
    "stripe:setup": "tsx scripts/setup-stripe.ts",
    "users:delete": "tsx scripts/delete-user.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.996.0",
    "@aws-sdk/client-kms": "^3.996.0",
    "@aws-sdk/lib-dynamodb": "^3.996.0",
    "@causeflow/analytics": "workspace:*",
    "@causeflow/auth": "workspace:*",
    "@causeflow/forms": "workspace:*",
    "@causeflow/shared": "workspace:*",
    "@causeflow/ui": "workspace:*",
    "@clerk/nextjs": "^7.0.7",
    "@clerk/themes": "^2.4.57",
    "@sentry/nextjs": "^10.48.0",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "canvas-confetti": "^1.9.4",
    "jose": "^6.2.0",
    "lucide-react": "^0.474.0",
    "next": "^15.2.0",
    "next-intl": "^4.1.0",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@clerk/localizations": "^4.3.0",
    "@clerk/testing": "^2.0.17",
    "@opennextjs/aws": "3.9.14",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "25.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "postcss": "^8.5.0",
    "stripe": "^20.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
