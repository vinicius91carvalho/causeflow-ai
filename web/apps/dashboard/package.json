{
  "name": "@causeflow/dashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=${PORT:-3000} && next dev --hostname localhost -p $((PORT + 1))",
    "build": "tsc --noEmit --project tsconfig.build.json && next build",
    "start": "next start -p 3001",
    "lint": "biome lint ./src",
    "check-types": "tsc --noEmit --project tsconfig.build.json",
    "test": "cd ../.. && vitest run --project dashboard",
    "test:watch": "cd ../.. && vitest --project dashboard",
    "clean": "rm -rf .next",
    "credits:add": "tsx scripts/add-credits.ts"
  },
  "dependencies": {
    "@causeflow/analytics": "workspace:*",
    "@causeflow/auth": "workspace:*",
    "@causeflow/forms": "workspace:*",
    "@causeflow/shared": "workspace:*",
    "@causeflow/ui": "workspace:*",

    "@sentry/nextjs": "^10.48.0",
    "canvas-confetti": "^1.9.4",
    "jose": "^6.2.0",
    "lucide-react": "^0.474.0",
    "next": "^15.2.0",
    "next-intl": "^4.1.0",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@opennextjs/aws": "3.9.14",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "25.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
