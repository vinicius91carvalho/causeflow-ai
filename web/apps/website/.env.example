# CauseFlow Website — Environment Variables (open-source local runtime)
#
# Copy this file to `.env.local` for local dev. All variables are optional;
# leave them blank to run a fully local, no-external-SaaS build.
#
# The open-source runtime does NOT use Clerk, Stripe, AWS, Sentry, Loops.so,
# or SST. None of those variables are required (AC-045).

# --- Optional analytics (blank = no-op, no outbound calls) ---

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Microsoft Clarity project ID (from https://clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_ID=
