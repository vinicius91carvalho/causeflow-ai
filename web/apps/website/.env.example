# CauseFlow Website — Environment Variables (example)
#
# Copy this file to `.env.local` for local dev. SST injects stage-specific
# values at deploy time; do not commit `.env.local`.

# --- Public ---------------------------------------------------------------

# Where "Sign in" / "Open dashboard" CTAs on the marketing site should link to.
# Leave unset locally to default to http://localhost:3001 via getDashboardUrl().
NEXT_PUBLIC_DASHBOARD_URL=

# Deployment stage — SST sets this per environment.
# Values: 'development' | 'staging' | 'production'
NEXT_PUBLIC_DEPLOYMENT_STAGE=development

# Google Analytics 4 measurement ID (optional in dev)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID (optional in dev)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Private (server) -----------------------------------------------------

# Staging-auth gate password. Matches sst.config.ts.
STAGING_PASSWORD=causeflow-staging-2026

# Loops.so API key for the planned /api/notify email-marketing integration.
# Declared as a planned integration in docs; no runtime consumer exists yet.
# Set in apps/website/.env.local when the integration is implemented.
LOOPS_API_KEY=
