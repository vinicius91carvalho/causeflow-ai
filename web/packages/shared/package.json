{
  "name": "@causeflow/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/domain/types/index.ts",
    "./constants": "./src/domain/constants/index.ts",
    "./utils": "./src/application/utils/index.ts",
    "./domain/utils/deep-merge": "./src/domain/utils/deep-merge.ts",
    "./domain/utils/generate-id": "./src/domain/utils/generate-id.ts",
    "./domain/utils/slug": "./src/domain/utils/slug.ts",
    "./infrastructure/utils/request": "./src/infrastructure/utils/request.ts",
    "./i18n/*": "./src/infrastructure/i18n/messages/*.json",
    "./i18n/en": "./src/infrastructure/i18n/messages/en.json",
    "./i18n/pt-br": "./src/infrastructure/i18n/messages/pt-br.json",
    "./infrastructure/middleware/staging-auth": "./src/infrastructure/middleware/staging-auth.ts"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "test": "cd ../.. && vitest run --project shared",
    "test:watch": "cd ../.. && vitest --project shared",
    "lint": "biome lint ./src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
