# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Draft content
drafts/
*.draft.mdx

# Harness artifacts (planning/spec/journal files — not documentation pages;
# contain JSX-like text such as `<40` or `<Note>` that breaks MDX parsing)
plans/
tasks/
docs/
harness-progress/
session-learnings.md
INVARIANTS.md
CLAUDE.md
