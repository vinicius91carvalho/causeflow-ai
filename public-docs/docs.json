{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CauseFlow AI",
  "appearance": {
    "default": "light"
  },
  "colors": {
    "primary": "#1A8B6F",
    "light": "#4ECDC4",
    "dark": "#26233E"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@causeflow.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.causeflow.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/causeflowai",
      "github": "https://github.com/causeflow",
      "linkedin": "https://linkedin.com/company/causeflow"
    }
  },
